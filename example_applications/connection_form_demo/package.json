{
	"name": "pict-section-connection-form-example-connection-form-demo",
	"version": "0.0.1",
	"description": "Connection Form Demo — interactive showcase for pict-section-connection-form",
	"main": "source/Pict-Application-ConnectionFormDemo.js",
	"scripts": {
		"start": "node source/Pict-Application-ConnectionFormDemo.js",
		"build": "npx quack build && npx quack copy",
		"test": "echo \"no tests\" && exit 0"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"pict": "^1.0.364",
		"pict-application": "^1.0.33",
		"pict-view": "^1.0.68",
		"pict-section-connection-form": "file:../../"
	},
	"devDependencies": {
		"quackage": "^1.1.2"
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{ "from": "./html/*", "to": "./dist/" },
		{ "from": "./css/**", "to": "./dist/css/" },
		{ "from": "./node_modules/pict/dist/*", "to": "./dist/js/" }
	]
