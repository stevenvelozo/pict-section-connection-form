{
	"name": "pict-section-connection-form",
	"version": "0.0.2",
	"description": "Pict view that renders a schema-driven Meadow connection form. Consumes connection-form schemas exported by meadow-connection-* modules and aggregated by meadow-connection-manager.",
	"main": "source/Pict-Section-ConnectionForm.js",
	"scripts": {
		"start": "node source/Pict-Section-ConnectionForm.js",
		"build": "npx quack build",
		"test": "npx mocha -u tdd --exit --timeout 10000 test/*_tests.js",
		"example": "npx quack examples"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/stevenvelozo/pict-section-connection-form.git"
	},
	"keywords": [
		"pict",
		"meadow",
		"connection",
		"form",
		"schema"
	],
	"author": "Steven Velozo <steven@velozo.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/stevenvelozo/pict-section-connection-form/issues"
	},
	"homepage": "https://github.com/stevenvelozo/pict-section-connection-form#readme",
	"devDependencies": {
		"chai": "^4.3.10",
		"jsdom": "^25.0.1",
		"mocha": "^11.0.1",
		"pict": "^1.0.365",
		"pict-application": "^1.0.33",
		"quackage": "^1.2.0"
	},
	"overrides": {
		"braces": ">=3.0.3",
		"diff": ">=5.2.2",
		"form-data": ">=2.5.4",
		"micromatch": ">=4.0.8",
		"minimatch": ">=5.1.8",
		"postcss": ">=8.5.9",
		"qs": ">=6.14.1",
		"send": ">=0.19.0",
		"serialize-javascript": ">=6.0.2",
		"tough-cookie": ">=4.1.3"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		]
	},
	"dependencies": {
		"pict-view": "^1.0.68"
	}
}
